{
  "expo": {
    "name": "Brush Your Teeth",
    "slug": "brush-your-teeth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "brushyourteeth",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFFFE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.igwestudios.brushyourteeth",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to verify your brushing and flossing.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFFFE"
      },
      "package": "com.igwestudios.brushyourteeth",
      "permissions": ["CAMERA", "NOTIFICATIONS"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Brush Your Teeth to access your camera to verify brushing and flossing."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
